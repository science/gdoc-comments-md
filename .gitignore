# Dependencies
node_modules/

# Build outputs
.svelte-kit/
build/
dist/

# Environment files
.env
.env.*
env.local
!.env.example

# Local sample / test documents (never commit real docs)
*.docx

# Files the user explicitly marked "gitignore" by filename (bug reports,
# scratch notes, etc.). Keeps private material out of the repo even if
# it lives at paths git would otherwise track.
gitignore-*

# Google OAuth credentials
client_secret_*.json
*.json:Zone.Identifier

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test artifacts
coverage/
playwright-report/
test-results/

# Logs
*.log
npm-debug.log*
